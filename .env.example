# ========================================
# MEMORY DOCS - Environment Configuration
# ========================================

# === Container Ports (INSIDER - inside Docker container) ===
# These are fixed and should NOT be changed
DOCS_CONTAINER_PORT=3000
MINIO_API_CONTAINER_PORT=9000
MINIO_CONSOLE_CONTAINER_PORT=9001

# === Host Ports (OUTSIDER - from your machine) ===
# These ports expose the containers to your localhost
# Change these if ports conflict with other apps
DOCS_HOST_PORT=3001
MINIO_API_HOST_PORT=9010
MINIO_CONSOLE_HOST_PORT=9011

# === MinIO Configuration ===
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
MINIO_BUCKET_NAME=media
MINIO_REGION=us-east-1

# === Docusaurus Configuration ===
NODE_ENV=development

